; ===========================================
; CAVA Configuration for a "Nice Effect"
; ===========================================
; This configuration aims for a smooth, visually appealing,
; and responsive audio visualization in your terminal.

[general]
framerate = 60          ; Higher framerate for smoother animations (adjust based on your terminal/system performance)
bars = 0                ; 0 means CAVA will automatically fill the terminal width with bars
bar_width = 2           ; Width of each individual bar (characters)
bar_spacing = 1         ; Space between bars (characters)
relative_bar_height = 1 ; If set to 1, all bars will fill the output height; 0 means they use their actual height.
fixedbars = 0           ; If 1, bars will not adjust width when resizing terminal. Keep at 0 for fluid resizing.
fftsize = 2048          ; FFT (Fast Fourier Transform) size. Larger values give more frequency resolution but use more CPU.
sleep_timer = 0         ; Delay between drawing frames (milliseconds). 0 means no delay.

[input]
method = pulse          ; Input method. Common choices: "pulse" (PulseAudio), "alsa" (ALSA), "portaudio" (macOS/Windows, if compiled with it).
                        ; For macOS, you might use "portaudio". For Linux, "pulse" or "alsa".
source = auto           ; Automatically detects the default audio source.
                        ; If you have issues, you might need to specify it, e.g., source = "alsa_output.pci-0000_00_1f.3.analog-stereo.monitor"
                        ; Use `pactl list short sinks` on PulseAudio to find monitor sources.
mono_auto = 1           ; If input is stereo, CAVA will average channels to mono automatically if mono_input is set to 1.
mono_input = 0          ; If 1, averages stereo input to mono before processing. Keep at 0 for separate channels.

[output]
method = ncurses        ; Output method. "ncurses" is standard for terminal.
channels = stereo       ; How to visualize channels. "stereo" mirrors left/right channels, "mono" averages them.
stereo_separation = 1   ; If stereo, 0 means no separation, higher values increase it.
reversed_bars = 0       ; If 1, bars will be rendered from bottom-to-top. (For "upwards" visualizer)

[smoothing]
integral = 70           ; How much previous values influence current bar heights (0-100%). Higher = smoother.
monstercat = 1          ; Enable "Monstercat" smoothing effect for a unique, fluid animation.
waves = 1               ; If monstercat is enabled, this adds a wave-like falloff effect.
gravity = 100           ; How fast bars fall down (0-200%). Higher = faster fall.
ignore = 0              ; Percentage of values at the lower end of the spectrum to ignore for smoothing. (0-100%)
noise_reduction = 0.7   ; Reduce flickering caused by low-level noise in the audio signal. (0-1.0)

[color]
; Define your gradient colors here. You can use predefined names or hex codes (#RRGGBB).
; Example: "cyan", "blue", "magenta", "red", "yellow", "green", "white", "black"
gradient = 1            ; Set to 1 to enable gradient colors.
gradient_count = 3      ; Number of colors in your gradient (up to 8).
gradient_color_1 = '#00FFFF' ; Cyan
gradient_color_2 = '#800080' ; Purple
gradient_color_3 = '#FF00FF' ; Magenta

; If you prefer solid colors, set gradient = 0 and uncomment/set these:
; foreground = "cyan"
; background = "black"

[eq]
; Equalizer settings to adjust sensitivity for different frequency ranges.
; Values represent gain (in dB). Adjust these to make certain frequencies more prominent.
; This example aims for a fairly balanced response.
; Low Freq (Bass) -------> Mid Freq ---------> High Freq (Treble)
1=1.00
2=1.00
3=1.00
4=1.00
5=1.00
